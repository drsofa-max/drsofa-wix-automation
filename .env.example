# Database
DATABASE_URL=postgresql://user:password@localhost/drsofa_db

# Flask
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Wix (These are set by users via API, but defaults can go here)
WIX_API_KEY=your-wix-api-key
WIX_ACCOUNT_ID=your-wix-account-id
CLOUDFLARE_PROXY_URL=https://your-worker.workers.dev

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-bytes-base64-encoded

# Email (for notifications)
SENDGRID_API_KEY=sg-your-sendgrid-api-key
SENDER_EMAIL=automation@drsofa.com

# Scheduling
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=US/Eastern

# Server
HOST=0.0.0.0
PORT=5000
